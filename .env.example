# Public site URL (no trailing slash) — used for metadata, OG URLs, sitemap, JSON-LD
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Contact form — pick one (or both). Never commit real keys.

# Option A: Resend (https://resend.com) — recommended for Vercel
RESEND_API_KEY=re_xxxxxxxx
# Must be a verified sender in Resend (e.g. Portfolio <onboarding@resend.dev> for tests)
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"
# Optional; defaults to profile.email in src/lib/data.ts
# CONTACT_TO_EMAIL=you@example.com

# Option B: any HTTPS endpoint (Slack incoming webhook, Zapier, etc.)
# CONTACT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Vercel sets these automatically (optional /api/health uses commit sha)
# VERCEL_GIT_COMMIT_SHA=
# VERCEL_ENV=production
